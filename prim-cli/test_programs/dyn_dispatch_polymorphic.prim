import std.io.println_i32

struct Counter { n: i32 }
struct Doubler { n: i32 }

trait Yieldable {
    fn yield_value(self) -> i32;
}

impl Yieldable for Counter {
    fn yield_value(self) -> i32 {
        self.n
    }
}

impl Yieldable for Doubler {
    fn yield_value(self) -> i32 {
        self.n + self.n
    }
}

fn extract(y: Yieldable) -> i32 {
    y.yield_value()
}

fn main() {
    let c = Counter { n = 21 }
    let d = Doubler { n = 100 }
    // Same function, same call site, different vtables dispatched.
    println_i32(extract(c))   // 21
    println_i32(extract(d))   // 200
}
