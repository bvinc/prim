import std.io.println_i32

struct Counter { n: i32 }

trait Greeter {
    fn greet(self) -> i32;
}

impl Greeter for Counter {
    fn greet(self) -> i32 { self.n }
}

fn main() {
    let c = Counter { n = 99 }
    // Coerce a concrete value into a trait at let-binding time.
    let g: Greeter = c
    println_i32(g.greet())
}
