import std.io.println_usize
import std.mem.size_of

struct Pair {
    a: i32,
    b: i32,
}

// size_of[T]() folds to a constant per type: scalars use their natural
// width; structs are 4-byte heap references.
fn main() {
    println_usize(size_of[u8]())     // 1
    println_usize(size_of[u16]())    // 2
    println_usize(size_of[u32]())    // 4
    println_usize(size_of[u64]())    // 8
    println_usize(size_of[bool]())   // 1
    println_usize(size_of[Pair]())   // 4
}
