import std.io.println_i32

struct Counter {
    n: i32,
}

trait Greeter {
    fn greet(self) -> i32;
}

impl Greeter for Counter {
    fn greet(self) -> i32 {
        self.n
    }
}

// Function takes a trait — the call site coerces the concrete struct
// into a fat pointer, and the method call inside dispatches dynamically
// through the vtable.
fn use_greeter(g: Greeter) -> i32 {
    g.greet()
}

fn main() {
    let c = Counter { n = 42 }
    println_i32(use_greeter(c))
}
