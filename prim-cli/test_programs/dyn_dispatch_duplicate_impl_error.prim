// Negative test: two impls with the same method on the same struct
// must be rejected.

struct Counter { n: i32 }

trait Greeter {
    fn greet(self) -> i32;
}

trait Other {
    fn greet(self) -> i32;
}

impl Greeter for Counter {
    fn greet(self) -> i32 { self.n }
}

impl Other for Counter {
    fn greet(self) -> i32 { self.n + 1i32 }
}

fn main() {
    let c = Counter { n = 1 }
    c.greet();
}
